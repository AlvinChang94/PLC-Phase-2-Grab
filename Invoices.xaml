                    <ui:InvokeCode ContinueOnError="{x:Null}" Code="' 1. Initialize Merged Tables&#xD;&#xA;dt_MergedB = dt_ExistB.Clone()&#xD;&#xA;dt_MergedDEFG = dt_ExistDEFG.Clone()&#xD;&#xA;dt_MergedJKL = dt_ExistJKL.Clone()&#xD;&#xA;&#xD;&#xA;' 2. Identify new dates from dt_InvoiceData (ColB is Index 0)&#xD;&#xA;Dim newDates As New HashSet(Of DateTime)()&#xD;&#xA;For Each row As DataRow In dt_InvoiceData.Rows&#xD;&#xA;    Dim d As DateTime&#xD;&#xA;    If DateTime.TryParse(row(0).ToString(), d) Then&#xD;&#xA;        newDates.Add(d.Date)&#xD;&#xA;    End If&#xD;&#xA;Next&#xD;&#xA;&#xD;&#xA;' 3. Process existing data (FILTERING OUT THE -2 BILLIONS HERE)&#xD;&#xA;Dim combinedRows As New List(Of Object())&#xD;&#xA;For i As Integer = 0 To dt_ExistB.Rows.Count - 1&#xD;&#xA;    ' Safety check to ensure matching rows across all blocks&#xD;&#xA;    If i &gt;= dt_ExistDEFG.Rows.Count OrElse i &gt;= dt_ExistJKL.Rows.Count Then Continue For&#xD;&#xA;    &#xD;&#xA;    ' YOUR IDEA: Check if Column D (Index 0 of dt_ExistDEFG) is blank. &#xD;&#xA;    ' If it is blank, skip the row entirely! This leaves the -2 billions behind.&#xD;&#xA;    Dim colD_Value As String = dt_ExistDEFG.Rows(i)(0).ToString()&#xD;&#xA;    If String.IsNullOrWhiteSpace(colD_Value) Then &#xD;&#xA;        Continue For &#xD;&#xA;    End If&#xD;&#xA;    &#xD;&#xA;    ' Also check if the Date is blank&#xD;&#xA;    Dim rawDate As String = dt_ExistB.Rows(i)(0).ToString()&#xD;&#xA;    If String.IsNullOrWhiteSpace(rawDate) Then Continue For&#xD;&#xA;    &#xD;&#xA;    Dim d As DateTime&#xD;&#xA;    Dim isDate As Boolean = DateTime.TryParse(rawDate, d)&#xD;&#xA;    &#xD;&#xA;    ' Overwrite Rule: Keep old row ONLY if date is NOT in the new run&#xD;&#xA;    If Not isDate OrElse Not newDates.Contains(d.Date) Then&#xD;&#xA;        Dim rowData(7) As Object&#xD;&#xA;        rowData(0) = dt_ExistB.Rows(i)(0)&#xD;&#xA;        rowData(1) = dt_ExistDEFG.Rows(i)(0)&#xD;&#xA;        rowData(2) = dt_ExistDEFG.Rows(i)(1)&#xD;&#xA;        rowData(3) = dt_ExistDEFG.Rows(i)(2)&#xD;&#xA;        rowData(4) = dt_ExistDEFG.Rows(i)(3)&#xD;&#xA;        rowData(5) = dt_ExistJKL.Rows(i)(0)&#xD;&#xA;        rowData(6) = dt_ExistJKL.Rows(i)(1)&#xD;&#xA;        rowData(7) = dt_ExistJKL.Rows(i)(2)&#xD;&#xA;        combinedRows.Add(rowData)&#xD;&#xA;    End If&#xD;&#xA;Next&#xD;&#xA;&#xD;&#xA;' 4. Append new data&#xD;&#xA;For Each row As DataRow In dt_InvoiceData.Rows&#xD;&#xA;    Dim rowData(7) As Object&#xD;&#xA;    rowData(0) = row(0) ' B&#xD;&#xA;    rowData(1) = row(1) ' D&#xD;&#xA;    rowData(2) = row(2) ' E&#xD;&#xA;    rowData(3) = row(3) ' F&#xD;&#xA;    rowData(4) = row(4) ' G&#xD;&#xA;    rowData(5) = row(5) ' J&#xD;&#xA;    rowData(6) = row(6) ' K&#xD;&#xA;    rowData(7) = row(7) ' L&#xD;&#xA;    combinedRows.Add(rowData)&#xD;&#xA;Next&#xD;&#xA;&#xD;&#xA;' 5. Sort chronologically by the date column (Index 0 / Col B)&#xD;&#xA;combinedRows = combinedRows.OrderBy(Function(x) &#xD;&#xA;    Dim d As DateTime&#xD;&#xA;    If DateTime.TryParse(x(0).ToString(), d) Then Return d&#xD;&#xA;    Return DateTime.MaxValue&#xD;&#xA;End Function).ToList()&#xD;&#xA;&#xD;&#xA;' 6. Populate the final separated tables&#xD;&#xA;For Each item In combinedRows&#xD;&#xA;    dt_MergedB.Rows.Add(item(0))&#xD;&#xA;    dt_MergedDEFG.Rows.Add(item(1), item(2), item(3), item(4))&#xD;&#xA;    dt_MergedJKL.Rows.Add(item(5), item(6), item(7))&#xD;&#xA;Next" DisplayName="Invoke Code" sap:VirtualizedContainerService.HintSize="416,197" sap2010:WorkflowViewState.IdRef="InvokeCode_1">
